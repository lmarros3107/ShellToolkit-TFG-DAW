SECRET_KEY=change-me-with-a-strong-random-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ADMIN_URL=secret-admin-panel/
CSP_REPORT_URI=

# PostgreSQL for production (Docker Compose)
POSTGRES_DB=shelltoolkit
POSTGRES_USER=shelltoolkit
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgres://shelltoolkit:change-this-password@db:5432/shelltoolkit

# Optional local-only switch for deploy checks without PostgreSQL
USE_SQLITE_FOR_CHECK=False
